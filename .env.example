# Copiază în .env.local pentru development local.
# Pe Vercel: Project → Settings → Environment Variables (Production + Preview).

# URL public canonical (OAuth / email redirects). Ex.: https://dormmate.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Doar ORIGIN-ul proiectului: https://ABCDEF.supabase.co (fără / la final; fără /auth sau /rest)
NEXT_PUBLIC_SUPABASE_URL=
# În dashboard: legacy „anon (public)” sau noul Publishable Key (sb_publishable_…).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opțional — același email ca în Supabase `is_platform_super_admin()` (implicit în cod).
# PLATFORM_SUPER_ADMIN_EMAIL=dariusdavid725@gmail.com

# Opțional — doar backend (NICIODATĂ NEXT_PUBLIC_*): bypass RLS pentru admin/scripturi.
# În dashboard: „service_role” (JWT) sau noul Secret Key (sb_secret_…).
# SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — receipt scanning (Vision). Server-only; never NEXT_PUBLIC_*.
# Dashboard → API Keys → create secret key.
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini)
# OPENAI_RECEIPT_MODEL=gpt-4o-mini
# Optional timeout in ms for AI receipt call (default 18000)
# OPENAI_RECEIPT_TIMEOUT_MS=18000
